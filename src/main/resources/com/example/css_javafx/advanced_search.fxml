<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.css_javafx.controller.AdvancedSearchController"
            fitToWidth="true"
            hbarPolicy="NEVER">
    <styleClass>
        <String fx:value="scroll"/>
        <String fx:value="advanced-search-scroll"/>
    </styleClass>

    <content>
        <VBox spacing="16">
            <styleClass>
                <String fx:value="center"/>
                <String fx:value="advanced-search-page"/>
            </styleClass>

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Advanced Search" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Back" onAction="#onBack">
                    <styleClass>
                        <String fx:value="btn"/>
                        <String fx:value="btn-ghost"/>
                    </styleClass>
                </Button>
            </HBox>

            <Label text="Use multiple parameters to find anime more precisely."
                   wrapText="true"
                   styleClass="status"/>

            <GridPane hgap="14" vgap="14">
                <styleClass>
                    <String fx:value="card"/>
                    <String fx:value="advanced-search-form"/>
                </styleClass>

                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <columnConstraints>
                    <ColumnConstraints minWidth="130"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Title" styleClass="sidebar-title" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="titleField"
                           promptText="Anime title"
                           styleClass="search"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Studio" styleClass="sidebar-title" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="studioField"
                           promptText="Studio"
                           styleClass="search"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Type" styleClass="sidebar-title" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="typeBox"
                          GridPane.rowIndex="2"
                          GridPane.columnIndex="1"
                          maxWidth="1.7976931348623157E308"/>

                <Label text="Season" styleClass="sidebar-title" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="seasonBox"
                          GridPane.rowIndex="3"
                          GridPane.columnIndex="1"
                          maxWidth="1.7976931348623157E308"/>

                <Label text="Year" styleClass="sidebar-title" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <ComboBox fx:id="yearBox"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="1"
                          maxWidth="1.7976931348623157E308"/>

                <Label text="Min score" styleClass="sidebar-title" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="minScoreField"
                           promptText="e.g. 7.5"
                           styleClass="search"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="1"/>
            </GridPane>

            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <styleClass>
                    <String fx:value="advanced-search-card"/>
                </styleClass>

                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <Label text="Genres" styleClass="sidebar-title"/>

                <Label text="Select multiple genres with Ctrl / Shift"
                       wrapText="true"
                       styleClass="status"/>

                <ListView fx:id="genreList" prefHeight="260" VBox.vgrow="ALWAYS">
                    <styleClass>
                        <String fx:value="genre-list"/>
                    </styleClass>
                </ListView>
            </VBox>

            <Label fx:id="infoLabel" text=" " styleClass="status"/>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button text="Reset" onAction="#onReset">
                    <styleClass>
                        <String fx:value="btn"/>
                        <String fx:value="btn-ghost"/>
                    </styleClass>
                </Button>

                <Button text="Apply" onAction="#onApply">
                    <styleClass>
                        <String fx:value="btn"/>
                        <String fx:value="btn-primary"/>
                    </styleClass>
                </Button>
            </HBox>
        </VBox>
    </content>
</ScrollPane>