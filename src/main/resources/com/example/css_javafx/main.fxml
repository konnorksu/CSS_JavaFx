<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="root" styleClass="app-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.css_javafx.controller.MainController">

    <top>
        <VBox spacing="0">
            <HBox fx:id="windowBar"
                  alignment="CENTER_LEFT"
                  spacing="6"
                  styleClass="window-bar">

                <padding>
                    <Insets top="4" right="4" bottom="4" left="8"/>
                </padding>

                <Label fx:id="windowTitle" text=" " styleClass="window-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="minBtn" text="—" onAction="#onMinimizeWindow" styleClass="window-btn"/>
                <Button fx:id="maxBtn" text="□" onAction="#onMaximizeWindow" styleClass="window-btn"/>
                <Button fx:id="closeBtn" text="X" onAction="#onCloseWindow">
                    <styleClass>
                        <String fx:value ="window-btn" />
                        <String fx:value = "window-btn-close"/>
                    </styleClass>
                </Button>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT" styleClass="topbar" BorderPane.alignment="CENTER">
                <padding>
                    <Insets top="6" right="8" bottom="6" left="8"/>
                </padding>

                <Label text="Anime Catalog" styleClass="brand"/>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="searchField"
                           promptText="Search anime..."
                           prefWidth="260"
                           styleClass="search"
                           onAction="#onSearch"/>

                <Button text="Search" onAction="#onSearch">
                    <styleClass>
                        <String fx:value="btn"/>
                        <String fx:value="btn-primary"/>
                    </styleClass>
                </Button>

                <Button text="Advanced Search" onAction="#onOpenAdvancedSearch">
                    <styleClass>
                        <String fx:value="btn"/>
                        <String fx:value="btn-ghost"/>
                    </styleClass>
                </Button>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="240" spacing="10" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

            <Label styleClass="sidebar-title" text="Menu" />
            <Button text="Catalog" onAction="#onOpenCatalog">
                <styleClass>
                    <String fx:value="nav-btn" />
                    <String fx:value="nav-btn-active" />
                </styleClass>
            </Button>

            <Button fx:id="settingsBtn" styleClass="nav-btn" text="Custom Theme" onAction="#onOpenSettings"/>

            <Separator styleClass="sep" />

            <Label text="Theme" styleClass="sidebar-title"/>

            <ComboBox fx:id="themeComboBox" prefWidth="180">
                <styleClass>
                    <String fx:value="combo-box-popup" />
                </styleClass>
            </ComboBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" styleClass="center" BorderPane.alignment="CENTER">
            <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

            <HBox alignment="CENTER_LEFT">
                <Label styleClass="section-title" text="Recommendation" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusText" styleClass="status" text=" " />
            </HBox>

            <StackPane>
                <ScrollPane fx:id="scroll" fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll">
                    <content>
                        <FlowPane fx:id="cards" hgap="14" prefWrapLength="860" styleClass="cards" vgap="14" />
                    </content>
                </ScrollPane>

                <ProgressIndicator fx:id="loading" styleClass="loading" visible="false" />
            </StackPane>
        </VBox>
    </center>

</BorderPane>