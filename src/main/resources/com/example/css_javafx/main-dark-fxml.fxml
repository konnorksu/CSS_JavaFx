<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.css_javafx.controller.MainController"
            style="-fx-background-color: #0f1220; -fx-font-family: 'Segoe UI';">

    <top>
        <VBox spacing="0">
            <HBox fx:id="windowBar"
                  alignment="CENTER_LEFT"
                  spacing="6"
                  style="-fx-background-color: #12162a; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0; -fx-padding: 4 6 4 8;">

                <Label fx:id="windowTitle"
                       text=" "
                       style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: 700;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="minBtn"
                        text="—"
                        onAction="#onMinimizeWindow"
                        style="-fx-min-width: 28; -fx-pref-width: 28; -fx-max-width: 28; -fx-min-height: 24; -fx-pref-height: 24; -fx-max-height: 24; -fx-padding: 0; -fx-alignment: CENTER; -fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: rgba(255,255,255,0.08);"/>

                <Button fx:id="maxBtn"
                        text="□"
                        onAction="#onMaximizeWindow"
                        style="-fx-min-width: 28; -fx-pref-width: 28; -fx-max-width: 28; -fx-min-height: 24; -fx-pref-height: 24; -fx-max-height: 24; -fx-padding: 0; -fx-alignment: CENTER; -fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: rgba(255,255,255,0.08);"/>

                <Button fx:id="closeBtn"
                        text="X"
                        onAction="#onCloseWindow"
                        style="-fx-min-width: 28; -fx-pref-width: 28; -fx-max-width: 28; -fx-min-height: 24; -fx-pref-height: 24; -fx-max-height: 24; -fx-padding: 0; -fx-alignment: CENTER; -fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: rgba(255,255,255,0.08);"/>
            </HBox>

            <HBox spacing="8"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.04); -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets top="6" right="8" bottom="6" left="8"/>
                </padding>

                <Label text="Anime Catalog"
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="searchField"
                           promptText="Search anime..."
                           prefWidth="260"
                           onAction="#onSearch"
                           style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.35); -fx-border-color: rgba(255,255,255,0.10); -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 12 10 12;"/>

                <Button text="Search"
                        onAction="#onSearch"
                        style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 14 10 14; -fx-font-weight: 800;"/>

                <Button text="Advanced Search"
                        onAction="#onOpenAdvancedSearch"
                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 14 10 14; -fx-font-weight: 800;"/>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="240"
              spacing="10"
              style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="16" left="16" right="16" top="16"/>
            </padding>

            <Label text="Menu"
                   style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px; -fx-font-weight: 700; -fx-padding: 0 0 10 0;"/>

            <Button text="Catalog"
                    onAction="#onOpenCatalog"
                    style="-fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-background-radius: 12; -fx-background-color: rgba(255,255,255,0.10); -fx-text-fill: white;"/>

            <Button fx:id="settingsBtn"
                    text="Custom Theme"
                    onAction="#onOpenSettings"
                    style="-fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-background-radius: 12; -fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75);"/>

            <Separator opacity="0.35"/>

            <Label text="Theme"
                   style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px; -fx-font-weight: 700; -fx-padding: 0 0 10 0;"/>

            <ComboBox fx:id="themeComboBox"
                      prefWidth="180"
                      style="-fx-background-color: rgba(255,255,255,0.06); -fx-border-color: rgba(255,255,255,0.10); -fx-background-radius: 12; -fx-border-radius: 12;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets bottom="16" left="16" right="16" top="16"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Recommendation"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 800;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusText"
                       text=" "
                       style="-fx-text-fill: rgba(255,255,255,0.65);"/>
            </HBox>

            <StackPane>
                <ScrollPane fx:id="scroll"
                            fitToWidth="true"
                            hbarPolicy="NEVER"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <FlowPane fx:id="cards" hgap="14" prefWrapLength="860" vgap="14"/>
                    </content>
                </ScrollPane>

                <ProgressIndicator fx:id="loading" visible="false" style="-fx-progress-color: #6c5ce7;"/>
            </StackPane>
        </VBox>
    </center>

</BorderPane>