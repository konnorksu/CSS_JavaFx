<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.media.MediaView?>
<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.css_javafx.controller.DetailsController"
            fitToWidth="true" hbarPolicy="NEVER"
            styleClass="scroll">

    <content>
        <VBox spacing="14" styleClass="details">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <Button fx:id="backBtn" text="← Back" styleClass="btn btn-ghost"/>

            <HBox spacing="16" alignment="TOP_LEFT">
                <ImageView fx:id="image"
                           fitWidth="260" fitHeight="360"
                           preserveRatio="true"
                           styleClass="details-image"/>

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label fx:id="title" wrapText="true" styleClass="details-title"/>
                    <TextArea fx:id="desc" wrapText="true" editable="false" styleClass="details-desc"/>
                    <Button fx:id="openBtn" text="Open page" styleClass="btn btn-primary"/>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
